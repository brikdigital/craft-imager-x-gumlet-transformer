{% import '_includes/forms.twig' as forms %}

<style>
    .field:first-of-type {
        margin-top: 0;
    }
</style>

{{ forms.autosuggestField({
    label: "Gumlet Subdomain",
    name: "subdomain",
    suggestEnvVars: true,
    value: settings.subdomain,
    required: true,
    errors: settings.getErrors('subdomain')
}) }}

{{ forms.autosuggestField({
    label: "API Key",
    name: "apiKey",
    suggestEnvVars: true,
    value: settings.apiKey,
    required: true,
    errors: settings.getErrors('apiKey')
}) }}

{{ forms.autosuggestField({
    label: 'Custom Domain',
    name: 'customDomain',
    suggestEnvVars: true,
    value: settings.customDomain,
    required: false,
    errors: settings.getErrors('customDomain')
}) }}

{{ forms.autosuggestField({
    label: 'Signing Key',
    name: 'signingKey',
    suggestEnvVars: true,
    value: settings.signingKey,
    required: false,
    errors: settings.getErrors('signingKey')
}) }}

{{ forms.checkbox({
    label: "Use Gumlet in Control Panel",
    name: "hookCpImages",
    checked: settings.hookCpImages,
    required: false,
    errors: settings.getErrors('hookCpImages')
}) }}